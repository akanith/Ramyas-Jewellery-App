# ============================================================
# Ramyas-App Monorepo — Global .gitignore
# ============================================================

# ── OS & Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ── Node / Next.js ──────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
dist/
build/
.cache/
.eslintcache
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
*.tsbuildinfo
next-env.d.ts

# ── Flutter / Dart ──────────────────────────────────────────
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/pubspec.lock
**/.pub-cache/
**/.pub/
**/*.g.dart
**/*.freezed.dart
**/*.mocks.dart
**/coverage/
**/doc/api/

# ── Supabase ────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/

# ── Firebase ────────────────────────────────────────────────
google-services.json
GoogleService-Info.plist
firebase-adminsdk-*.json

# ── Secrets & Credentials ───────────────────────────────────
*.pem
*.key
*.p12
*.cer
*.mobileprovision
secrets/
.secrets/

# ── Logs ────────────────────────────────────────────────────
logs/
*.log

# ── Test Coverage ───────────────────────────────────────────
coverage/
lcov.info

# ── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
tmp/


# Environment variables
.env
.env.local
.env.*.local